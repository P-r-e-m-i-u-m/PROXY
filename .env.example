# ============================================================
#  OpenAI Reverse Proxy — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# Port the proxy listens on (default: 3000)
PORT=3000

# ------------------------------------------------------------
# Providers
# Add as many numbered providers as you like (PROVIDER_1_, PROVIDER_2_, …)
# The proxy will load-balance across providers that support the requested model.
# ------------------------------------------------------------

# --- Provider 1 (required if you want a custom upstream) ---
PROVIDER_1_NAME=my-free-provider
PROVIDER_1_BASE_URL=https://your-free-openai-compatible-endpoint.example.com

# Optional: if the upstream requires an API key
# PROVIDER_1_API_KEY=sk-xxxx

# Optional: comma-separated model name prefixes this provider handles.
# Leave empty to make it a catch-all.
# PROVIDER_1_MODEL_PREFIXES=gpt-,text-

# Weight for load-balancing (higher = more traffic). Default: 1
# PROVIDER_1_WEIGHT=1

# --- Provider 2 (optional fallback) ---
# PROVIDER_2_NAME=fallback-provider
# PROVIDER_2_BASE_URL=https://another-endpoint.example.com
# PROVIDER_2_API_KEY=sk-yyyy
# PROVIDER_2_MODEL_PREFIXES=gpt-3
# PROVIDER_2_WEIGHT=1

# ------------------------------------------------------------
# Rate limiting (optional)
# ------------------------------------------------------------
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=100
